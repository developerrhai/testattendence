# SmartOffice API Configuration
# Get these from your SmartOffice Web Application settings

SMARTOFFICE_BASE_URL=http://YOUR_SERVER_IP:PORT
SMARTOFFICE_API_KEY=your_api_key_here

# Example (from the PDF docs):
# SMARTOFFICE_BASE_URL=http://45.118.183.175:86
# SMARTOFFICE_API_KEY=521714042205

# Database (replace with your actual DB connection)
# DATABASE_URL=postgresql://user:password@localhost:5432/institute_db
